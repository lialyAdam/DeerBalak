@using System.Security.Claims

@{
    var userName = User.FindFirstValue(ClaimTypes.Email);
    var fullName = User.FindFirstValue(ClaimTypes.Name);
    var profilePictureUrl = User.FindFirstValue("ProfilePictureUrl");
}

<header class="navbar">
    <div class="logo-section">
        <button uk-toggle="target: #site__sidebar ; cls :!-translate-x-0"
                class="flex items-center justify-center w-8 h-8 text-xl rounded-full hover:bg-gray-100 xl:hidden group mr-2">
            <ion-icon name="menu-outline" class="text-2xl group-aria-expanded:hidden"></ion-icon>
            <ion-icon name="close-outline" class="hidden text-2xl group-aria-expanded:block"></ion-icon>
        </button>

        <div id="logo">
            <a asp-controller="Home" asp-action="Index" class="flex items-center">
                <img src="~/images/WhiteLogo.png" class="w-10 md:block hidden" />
                <span class="ml-2 text-lg font-semibold">DeerBalakAlena</span>
            </a>
        </div>
    </div>

    <div class="search-section">
        <form id="search--box" class="search-bar relative w-full max-w-[600px] rounded-full overflow-hidden bg-white border border-slate-200 shadow-sm flex">
            <ion-icon name="search" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500"></ion-icon>
            <input type="text" name="query" placeholder="Search Posts, Friends..." class="w-full pl-12 pr-4 h-12 rounded-full bg-white text-sm text-slate-700 border-none focus:outline-none focus:ring-2 focus:ring-slate-300" />
        </form>
    </div>

    <div class="icons-section relative">
        <button type="button" class="p-2 rounded-full hover:bg-gray-100 relative" id="notificationsBtn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                <path d="M5.85 3.5a.75.75 0 00-1.117-1 9.719 9.719 0 00-2.348 4.876.75.75 0 001.479.248A8.219 8.219 0 015.85 3.5zM19.267 2.5a.75.75 0 10-1.118 1 8.22 8.22 0 011.987 4.124.75.75 0 001.48-.248A9.72 9.72 0 0019.266 2.5z" />
                <path fill-rule="evenodd" d="M12 2.25A6.75 6.75 0 005.25 9v.75a8.217 8.217 0 01-2.119 5.52.75.75 0 00.298 1.206c1.544.57 3.16.99 4.831 1.243a3.75 3.75 0 107.48 0 24.583 24.583 0 004.83-1.244.75.75 0 00.298-1.205 8.217 8.217 0 01-2.118-5.52V9A6.75 6.75 0 0012 2.25zM9.75 18c0-.034 0-.067.002-.1a25.05 25.05 0 004.496 0l.002.1a2.25 2.25 0 11-4.5 0z" clip-rule="evenodd" />
            </svg>
            <div class="absolute top-0 right-0 -m-1 bg-red-600 text-white text-xs px-1 rounded-full" id="notificationsCount">0</div>
        </button>

        <div id="notification-dropdown" class="hidden absolute right-0 mt-2 w-80 max-h-96 overflow-y-auto bg-white rounded-xl shadow-xl border border-gray-200 z-50"></div>

        <div class="rounded-full relative cursor-pointer" id="profileBtn">
            <img loading="lazy" 
                 decoding="async"
                 src="@(string.IsNullOrEmpty(profilePictureUrl) ? Url.Content("~/images/avatar/user.png") : profilePictureUrl)" 
                 class="w-9 h-9 rounded-full shadow" />
        </div>

        <div id="profile-dropdown" class="hidden absolute right-0 mt-2 w-64 bg-white rounded-lg drop-shadow-xl border border-gray-200 z-50">
            <a>
                <div class="p-4 py-5 flex items-center gap-4">
                    <img loading="lazy" 
                         decoding="async"
                         src="@(string.IsNullOrEmpty(profilePictureUrl) ? Url.Content("~/images/avatar/user.png") : profilePictureUrl)" 
                         class="w-10 h-10 rounded-full shadow" />
                    <div class="flex-1">
                        <h4 class="text-sm font-medium text-black">@fullName</h4>
                        <div class="text-sm mt-1 text-blue-600 font-light">@userName</div>
                    </div>
                </div>
            </a>
            <hr />
            <nav>
                <a asp-controller="Settings" asp-action="Index">
                    <div class="flex items-center gap-2.5 hover:bg-gray-50 p-2 px-2.5 rounded-md">
                        <ion-icon name="settings-outline" class="text-lg"></ion-icon> My Account
                    </div>
                </a>
                <hr />
                <a asp-controller="Authentication" asp-action="Logout">
                    <div class="flex items-center gap-2.5 hover:bg-gray-50 p-2 px-2.5 rounded-md">
                        <ion-icon name="exit-outline" class="text-lg"></ion-icon> Log Out
                    </div>
                </a>
            </nav>
        </div>
    </div>
</header>

<script src="https://cdnjs.cloudflare.com/ajax/libs/aspnet-signalr/1.0.27/signalr.min.js" integrity="sha512-a+73ErrZPjhqOu0qbW1QLsenEF4pvDjmnd+Ws6hkDyJlrwAigOQAxQhIT+fPNFWScUvtJQvn+G535TT2C6/G4g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
    console.log('TopBar script loaded');

    document.addEventListener("DOMContentLoaded", () => {

        fetch("/Notifications/GetCount", {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json'
            }
        })
            .then(response => response.json())
            .then(data => {
                console.log("notifications count = ", data);
                document.getElementById("notificationsCount").innerHTML = data;
            })
            .catch(error => {
                console.error("Error fetching notification count: ", error);
            })


        //SignalR connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveNotification", (message) => {
            console.log("message ==> ", message);

            document.getElementById("notificationsCount").innerHTML = message;
        });

        connection.start()
            .then(() => console.log("SignalR connected"))
            .catch((err) => console.log("SignalR connection error: ", err))

        // Setup notification button event listener
        const notificationDropdown = document.getElementById('notification-dropdown');
        const notificationsBtn = document.getElementById('notificationsBtn');

        if (notificationsBtn && notificationDropdown) {
            console.log('Setting up notification button event listener');
            notificationsBtn.addEventListener('click', (e) => {
                console.log('Notifications button clicked');
                e.preventDefault();
                e.stopPropagation();
                if (!notificationDropdown.classList.contains('hidden')) {
                    notificationDropdown.classList.add('hidden');
                    return;
                }

                fetch('/Notifications/GetNotifications')
                    .then(resp => resp.text())
                    .then(html => {
                        notificationDropdown.innerHTML = html.trim() || '<div class="p-4 text-sm text-slate-500">No notifications yet</div>';
                        notificationDropdown.classList.remove('hidden');
                    })
                    .catch(error => {
                        console.error('Error loading notifications: ', error);
                    });
            });

            document.addEventListener('click', (event) => {
                if (!notificationDropdown.classList.contains('hidden') && !notificationDropdown.contains(event.target) && !notificationsBtn.contains(event.target)) {
                    notificationDropdown.classList.add('hidden');
                }
            });
        }

        // Setup profile button event listener
        const profileDropdown = document.getElementById('profile-dropdown');
        const profileBtn = document.getElementById('profileBtn');

        if (profileBtn && profileDropdown) {
            console.log('Setting up profile button event listener');
            profileBtn.addEventListener('click', (e) => {
                console.log('Profile button clicked');
                e.preventDefault();
                e.stopPropagation();
                if (!profileDropdown.classList.contains('hidden')) {
                    profileDropdown.classList.add('hidden');
                    return;
                }
                profileDropdown.classList.remove('hidden');
            });

            document.addEventListener('click', (event) => {
                if (!profileDropdown.classList.contains('hidden') && !profileDropdown.contains(event.target) && !profileBtn.contains(event.target)) {
                    profileDropdown.classList.add('hidden');
                }
            });
        }

    })

    function setNotificationAsRead(notificationId) {
        console.log('Mark as read => notification => ', notificationId);

        fetch(`/Notifications/SetNotificationAsRead?notificationId=${notificationId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
            .then(resp => resp.text())
            .then(html => {
                document.getElementById('notification-dropdown').innerHTML = html;
            })
    }
</script>