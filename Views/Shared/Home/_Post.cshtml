@using System.Security.Claims;
@model Post

@{
    int loggedInUserId = int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int result) ? result : 0;

    TimeSpan timeSpanSincePosted = DateTime.UtcNow.Subtract(Model.DateCreated);

    string displayTime = timeSpanSincePosted switch
    {
        var t when t.TotalDays >= 1 => $"{(int)t.TotalDays}d ago",
        var t when t.TotalHours >= 1 => $"{(int)t.TotalHours}h ago",
        var t when t.TotalMinutes >= 1 => $"{(int)t.TotalMinutes}m ago",
        _ => "Just now"
    };

    bool isFavorited = Model.Favorites.Any(n => n.UserId == loggedInUserId);
    bool isLiked = Model.Likes.Any(n => n.UserId == loggedInUserId);
    bool isPrivate = Model.IsPrivate == true && Model.UserId == loggedInUserId;
    bool isReported = Model.Reports.Any(n => n.UserId == loggedInUserId);

    bool showAllComments = ViewData["ShowAllComment"] as bool? ?? false;
    bool showDetails = ViewData["ShowDetails"] as bool? ?? true;

    var postLabel = string.IsNullOrWhiteSpace(Model.FakeNewsLabel)
        ? "Verified"
        : Model.FakeNewsLabel;

    // Helper functions for advanced features
    string GetRiskColorClass(string riskLevel) => riskLevel switch
    {
        "CRITICAL" => "text-red-600",
        "HIGH" => "text-orange-600",
        "MEDIUM" => "text-yellow-600",
        "LOW" => "text-blue-600",
        _ => "text-green-600"
    };

    string HighlightText(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return string.Empty;

        var dangerWords = new[] { "urgent", "danger" };
        var warningWords = new[] { "might", "heard" };
        var tokens = text.Split(' ');
        var builder = new System.Text.StringBuilder();

        for (int i = 0; i < tokens.Length; i++)
        {
            var token = tokens[i];
            var lowerToken = token.TrimEnd('.', ',', '!', '?').ToLower();
            var color = string.Empty;

            if (dangerWords.Contains(lowerToken))
                color = "red";
            else if (warningWords.Contains(lowerToken))
                color = "orange";

            var encoded = System.Net.WebUtility.HtmlEncode(token);
            if (!string.IsNullOrEmpty(color))
                builder.Append($"<span style=\"color:{color};font-weight:bold\">{encoded}</span>");
            else
                builder.Append(encoded);

            if (i < tokens.Length - 1)
                builder.Append(" ");
        }

        return builder.ToString();
    }

    string[] GetSuggestion(int score)
    {
        // Score mapping: 0-10 with new labels
        if (score >= 9)
        {
            return new[] { "🚨 DO NOT SHARE this content", "Requires immediate verification", "High likelihood of misinformation" };
        }

        if (score >= 7)
        {
            return new[] { "⚠️ Do not share without verification", "Verify with official sources first", "Check multiple reliable sources" };
        }

        if (score >= 5)
        {
            return new[] { "🟡 Be very cautious before sharing", "Check source credibility", "Seek additional verification" };
        }

        if (score >= 3)
        {
            return new[] { "🔵 Be cautious before sharing", "Cross-check with other sources", "Verify facts if possible" };
        }

        return new[] { "🟢 Content appears safe to share" };
    }

    string GetRiskEmoji(string riskLevel) => riskLevel switch
    {
        "CRITICAL" => "🔴",
        "HIGH" => "🟠",
        "MEDIUM" => "🟡",
        "LOW" => "🔵",
        _ => "🟢"
    };

    string GetConfidenceGradient(double confidence) => confidence switch
    {
        var c when c >= 80 => "from-red-500 to-red-600",
        var c when c >= 60 => "from-orange-500 to-red-500",
        var c when c >= 40 => "from-yellow-500 to-orange-500",
        var c when c >= 20 => "from-blue-500 to-yellow-500",
        _ => "from-green-500 to-blue-500"
    };
}

<div id="post-@Model.Id" class="bg-white rounded-xl shadow-sm text-sm font-medium border1">

    @* Post heading *@
    <div class="flex gap-3 sm:p-4 p-2.5 text-sm font-medium">
        <a asp-controller="Users" asp-action="Details" asp-route-userId="@Model.UserId">
            <img src="@(!string.IsNullOrEmpty(Model.User.ProfilePictureUrl) ?
        Model.User.ProfilePictureUrl :
        Url.Content("~/images/avatar/user.png"))" class="w-9 h-9 rounded-full" />
        </a>
        <div class="flex-1">
            <a asp-controller="Users" asp-action="Details" asp-route-userId="@Model.UserId">
                <h4 class="text-black">@Model.User.FullName</h4>
                <div class="text-xs text-gray-500/80" title="@Model.DateCreated.ToString("MM/dd/yyyy HH:mm")"> @displayTime </div>
            </a>

            <div class="mt-1">
                @if (postLabel == "Needs Verification")
                {
                    <span class="uppercase text-xs font-bold px-2 py-1 rounded-lg bg-red-100 text-red-700">Needs Verification</span>
                }
                else if (postLabel == "Unverified")
                {
                    <span class="uppercase text-xs font-bold px-2 py-1 rounded-lg bg-yellow-100 text-yellow-800">Unverified</span>
                }
                else
                {
                    <span class="uppercase text-xs font-bold px-2 py-1 rounded-lg bg-green-100 text-green-700">Verified</span>
                }
            </div>
        </div>

        <div class="-mr-1">
            <button type="button" class="button-icon w-8 h-8"> <ion-icon class="text-xl" name="ellipsis-horizontal"></ion-icon> </button>
            <div class="w-[245px] post-options-dropdown" uk-dropdown="pos: bottom-right; animation: uk-animation-scale-up uk-transform-origin-top-right; animate-out: true; mode: click">

                @if (Model.UserId == loggedInUserId)
                {
                    <form asp-controller="Home" asp-action="TogglePostVisibility">
                        <input type="hidden" name="postId" value="@Model.Id" />
                        <button type="submit" class="hover:!bg-red-50 icon-link">
                            <ion-icon name="@(isPrivate ? "lock-open-outline" : "lock-closed-outline")"></ion-icon>  Set as @(isPrivate ? "public" : "private")
                        </button>
                    </form>
                    <hr>

                    <button type="button" onclick="openPostDeleteConfirmation('@Model.Id')" class="text-red-400 hover:!bg-red-50 delete-post-btn">
                        <ion-icon name="trash-bin-outline"></ion-icon>  Delete Post
                    </button>
                }

                @if (!isReported)
                {
                    <form asp-controller="Home" asp-action="AddPostReport">
                        <input type="hidden" name="postId" value="@Model.Id" />
                        <button type="submit" class="hover:!bg-red-50 icon-link">
                            <ion-icon class="text-xl shrink-0" name="flag-outline"></ion-icon>  Report
                        </button>
                    </form>
                }

            </div>
        </div>
    </div>

    @* Post content *@
    @if (Model.FakeNewsScore >= 7)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-3 font-semibold">
            ⚠️ This post may contain misleading or urgent information
        </div>
    }

    <a asp-controller="Home" asp-action="Details" asp-route-postId="@Model.Id">
        <div class="sm:px-4 p-2.5 pt-0 w-full">
            <p class="font-normal post-content" data-content="@Model.Content">
                @Html.Raw(HighlightText(Model.Content))
            </p>
        </div>
    </a>

    <div class="sm:px-4 p-2.5 pt-0 w-full text-xs text-gray-600">
        <div>User Trust: <span class="font-semibold text-gray-800">@Model.UserTrustScore%</span></div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <a asp-controller="Home" asp-action="Details" asp-route-postId="@Model.Id">
            <div class="relative w-full h-full">
                <img src="@Model.ImageUrl" class="sm:rounded-lg w-full h-full object-cover" />
            </div>
        </a>
    }

    <div class="sm:px-4 p-2.5 border-t border-gray-100 bg-slate-50/50">
        <div class="flex flex-col gap-3 text-xs text-gray-700">
            <div class="flex flex-col gap-2">
                <div class="flex justify-between items-center">
                    <span class="font-semibold">Risk Score:</span>
                    <div class="flex items-center gap-2">
                        <span class="text-sm font-bold">@Model.FakeNewsScore</span>
                        <span class="text-xs text-gray-500">→</span>
                        <span class="text-sm font-bold @GetRiskColorClass(Model.RiskLevel)">@GetRiskEmoji(Model.RiskLevel) @Model.RiskLevel</span>
                    </div>
                </div>
                <div class="flex justify-between items-center">
                    <span class="font-semibold">Confidence:</span>
                    <span class="text-sm font-bold text-blue-600">@Math.Round(Model.ConfidenceLevel, 0)%</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-gradient-to-r @GetConfidenceGradient(Model.ConfidenceLevel) h-2 rounded-full transition-all duration-300"
                         style="width: @Math.Max(0, Math.Min(100, Model.ConfidenceLevel))%"></div>
                </div>
                <div class="text-center text-xs text-gray-500">@postLabel</div>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <span class="font-semibold">Similarity:</span>
                <span class="text-sm">@(Math.Round(Model.FakeNewsSimilarity * 100, 0))%</span>
            </div>

            <!-- 🚀 2) Context Tagging -->
            @if (!string.IsNullOrEmpty(Model.Category))
            {
                <div class="flex items-center gap-2">
                    <span class="font-semibold">Category:</span>
                    <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded-full text-xs font-medium">@Model.Category</span>
                </div>
            }

            <!-- 🚀 7) Post Priority -->
            @if (!string.IsNullOrEmpty(Model.Priority) && Model.Priority != "📝 Normal")
            {
                <div class="flex items-center gap-2">
                    <span class="font-semibold">Priority:</span>
                    <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded-full text-xs font-bold">@Model.Priority</span>
                </div>
            }

            <!-- 🚀 6) Community Signal -->
            @if (Model.ReportCount > 0)
            {
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-2">
                    <span class="text-yellow-800 text-xs font-medium">⚠️ Reported by @Model.ReportCount user@(Model.ReportCount > 1 ? "s" : "")</span>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.CommunitySignal))
            {
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-2">
                    <span class="text-yellow-800 text-xs font-medium">@Model.CommunitySignal</span>
                </div>
            }

            <!-- 🚀 3) Enhanced Risk Explanation Level -->
            @if (Model.FakeNewsReasons != null && Model.FakeNewsReasons.Any())
            {
                <div class="text-xs text-gray-600">
                    <div class="font-semibold mb-1">Risk Analysis:</div>
                    <ul class="space-y-1">
                        @foreach (var reason in Model.FakeNewsReasons)
                        {
                            <li class="flex items-start gap-2">
                                <span class="text-blue-500 mt-0.5">•</span>
                                <span class="tooltip-trigger cursor-help" title="@reason">@reason</span>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="mt-3 text-xs text-gray-700">
                <strong>Recommended Action:</strong>
                <ul class="list-disc list-inside ml-4 mt-2">
                    @foreach (var item in GetSuggestion(Model.FakeNewsScore))
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    @* Icons *@
    <div class="sm:p-4 p-2.5 flex items-center gap-4 text-xs font-semibold">

        <div class="flex items-center gap-2.5">
            <form asp-controller="Home" asp-action="TogglePostUseful">
                @Html.AntiForgeryToken()
                <input type="hidden" name="postId" value="@Model.Id" />
                <button type="submit" class="button-icon like-button @(isLiked ? "text-red-500 bg-red-100" : "")">
                    <ion-icon class="text-lg"
                              name="@(isLiked ? "heart" : "heart-outline")"></ion-icon>
                </button>
            </form>
            <a href="#">@Model.Likes.Count</a>

@*             <form asp-controller="Home" asp-action="TogglePostUseful">
                @Html.AntiForgeryToken()
                <input type="hidden" name="postId" value="@Model.Id" />
                <button type="submit" class="button-icon like-button @(isLiked ? "text-red-500 bg-red-100" : "")">
                    <ion-icon class="text-lg"
                              name="@(isLiked ? "heart" : "heart-outline")"></ion-icon>
                </button>
            </form>
 *@
        </div>



        <div class="flex items-center gap-3">
            <a class="button-icon">
                <ion-icon class="text-lg" name="chatbubble-ellipses-outline"></ion-icon>
            </a>
            <a href="#">@Model.Comments.Count</a>
        </div>

        <div class="ml-auto"></div>

        <div class="flex items-center gap-2">
            <form asp-controller="Home" asp-action="TogglePostFavorite">
                <input type="hidden" name="postId" value="@Model.Id" />
                <button type="submit" class="button-icon favorite-button ml-auto @(isFavorited ? "text-orange-500 bt-orange-100":"")">
                    <ion-icon class="text-lg" name="@(isFavorited ? "bookmark":"bookmark-outline")"></ion-icon>
                </button>
            </form>
            @if (Model.Favorites.Count > 0)
            {
                <a href="#">@Model.Favorites.Count</a>
            }
        </div>
    </div>

    @if (showDetails)
    {

        @* Add comment section *@
        <div>

            <div class="p-2.5 border-t border-gray-100 font-normal space-y-3 relative">

                @foreach (var comment in showAllComments
               ? Model.Comments.OrderByDescending(n => n.DateCreated)
               : Model.Comments.OrderByDescending(n => n.DateCreated).Take(2))
                {
                    TimeSpan commentTimeSpanSincePosted = DateTime.UtcNow.Subtract(comment.DateCreated);

                    string commentDisplayTime = commentTimeSpanSincePosted switch
                    {
                        var t when t.TotalDays >= 1 => $"{(int)t.TotalDays}d ago",
                        var t when t.TotalHours >= 1 => $"{(int)t.TotalHours}h ago",
                        var t when t.TotalMinutes >= 1 => $"{(int)t.TotalMinutes}m ago",
                        _ => "Just now"
                    };

                    <div class="flex items-start gap-3 relative">
                        <a asp-controller="Users" asp-action="Details" asp-route-userId="@comment.UserId">
                            <img src="@(!string.IsNullOrEmpty(comment.User.ProfilePictureUrl) ? comment.User.ProfilePictureUrl : Url.Content("~/images/avatar/user.png"))" class="w-6 h-6 mt-1 rounded-full" />
                        </a>
                        <div class="flex-1">
                            <div class="flex justify-content-between">
                                <a asp-controller="Users" asp-action="Details" asp-route-userId="@comment.UserId" class="text-black font-medium inline-block flex-grow">
                                    @comment.User.FullName
                                </a>
                                <small>@commentDisplayTime</small>
                            </div>
                            <div class="flex items-center justify-between">
                                <p class="mt-0.5">
                                    @comment.Content
                                </p>

                                <form asp-controller="Home" asp-action="RemovePostComment" class="remove-comment-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@comment.Id" />
                                    <input type="hidden" name="postId" value="@comment.PostId" />
                                    <button type="submit" class="text-red-500 text-xs ml-2" title="Remove post comment">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                }

                @if (Model.Comments.Count >= 3 && !showAllComments)
                {
                    <div class="p-1.5">
                        <a asp-controller="Home" asp-action="Details" asp-route-postId="@Model.Id">
                            Show all comments
                        </a>
                    </div>
                }

            </div>

            <form asp-controller="Home" asp-action="AddPostComment" class="add-comment-form">
                @Html.AntiForgeryToken()
                <div class="sm:px-4 sm:py-3 p-2.5 border-t border-gray-100 flex items-center gap-1">
                    <a asp-controller="Users" asp-action="Detalis" asp-route-userId="@Model.UserId">
                        <img src="@(string.IsNullOrEmpty(Model.User.ProfilePictureUrl) ? Url.Content("~/images/avatar/user.png") : Model.User.ProfilePictureUrl)" class="w-6 h-6 rounded-full" />
                    </a>


                    <input type="hidden" name="postId" value="@Model.Id" />
                    <div class="flex-1 relative overflow-hidden h-10">
                        <textarea name="content" placeholder="Add Comment...."
                                  rows="1"
                                  class="w-full resize-none !bg-transparent px-4 py-2 focus:!border-transparent focus:!ring-transparent"></textarea>
                    </div>

                    <button type="submit" class="text-sm rounded-full py-1.5 px-3.5 bg-secondery">Comment</button>
                </div>
            </form>
        </div>
    }

</div>

<script>
    // Keyword highlighting for urgent/danger words
    document.addEventListener('DOMContentLoaded', function() {
        const postContents = document.querySelectorAll('.post-content');
        const keywords = ['urgent', 'danger', 'breaking', 'emergency', 'crisis', 'alert', 'warning'];

        postContents.forEach(content => {
            let html = content.innerHTML;
            keywords.forEach(keyword => {
                const regex = new RegExp(`\\b${keyword}\\b`, 'gi');
                html = html.replace(regex, `<span class="text-red-600 font-bold bg-red-100 px-1 rounded">$&</span>`);
            });
            content.innerHTML = html;
        });
    });

    // Tooltip functionality
    document.addEventListener('DOMContentLoaded', function() {
        const tooltipTriggers = document.querySelectorAll('.tooltip-trigger');

        tooltipTriggers.forEach(trigger => {
            trigger.addEventListener('mouseenter', function(e) {
                // Remove any existing tooltips
                document.querySelectorAll('.custom-tooltip').forEach(t => t.remove());

                const tooltip = document.createElement('div');
                tooltip.className = 'custom-tooltip';
                tooltip.textContent = this.title;
                tooltip.style.cssText = `
                    position: absolute;
                    background: #374151;
                    color: white;
                    padding: 8px 12px;
                    border-radius: 6px;
                    font-size: 12px;
                    white-space: nowrap;
                    z-index: 1000;
                    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
                    pointer-events: none;
                `;

                document.body.appendChild(tooltip);

                const rect = this.getBoundingClientRect();
                tooltip.style.left = rect.left + (rect.width / 2) - (tooltip.offsetWidth / 2) + 'px';
                tooltip.style.top = rect.top - tooltip.offsetHeight - 8 + 'px';
            });

            trigger.addEventListener('mouseleave', function() {
                document.querySelectorAll('.custom-tooltip').forEach(t => t.remove());
            });
        });
    });
</script>


